# ADAPT — Environment variables
# Copy this file to .env and fill in the values you need.

# Fernet key for encrypting LLM API keys at rest.
# Generate one with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If left empty, a key is auto-generated on first run and stored in .secret_key
ADAPT_SECRET_KEY=

# Optional fallback Gemini key for solo-teacher local installs.
# If set, the teacher can skip the Settings screen entirely.
ADAPT_GEMINI_API_KEY=

# Sentence-transformers model for KB chunk embeddings.
# Default: all-MiniLM-L6-v2 (fast, free, ~80MB)
ADAPT_EMBEDDING_MODEL=all-MiniLM-L6-v2
