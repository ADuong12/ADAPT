# ADAPT Docker Configuration
# Copy this file to .env and fill in the values.
# DO NOT commit .env — it is already in .gitignore.

# ── Required ──────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=
# 64-char hex string for AES-256-GCM (generate same way as JWT_SECRET)
ENCRYPTION_KEY=

# ── Optional ───────────────────────────────────────────────────────
# Fallback LLM API key (teachers can also configure their own in the UI)
ADAPT_GEMINI_API_KEY=
# Fernet key for encrypting stored LLM API keys (auto-generated if empty)
ADAPT_SECRET_KEY=
# Embedding model used by the RAG pipeline (only used with --profile rag)
ADAPT_EMBEDDING_MODEL=all-MiniLM-L6-v2
# Port to expose on the host (default: 80)
ADAPT_PORT=80